# 示例环境变量（不要在仓库提交真实密码）
# Flask / 应用配置
SECRET_KEY=change_me_secret
DB_HOST=localhost
DB_USER=bidding_user
DB_PASSWORD=your_db_password
DB_NAME=bidding_db
DB_PORT=3306
ANALYSIS_ACCESS_CODE=kwd12345

# 日志与监控
# 是否启用 JSON 行格式日志（true/false）
LOG_JSON=false
# 日志按日轮转保留天数
LOG_BACKUP_DAYS=7

# 数据清理
# 清理脚本保留的天数（clear_old_data.py 默认值）
CLEANUP_DAYS=30
