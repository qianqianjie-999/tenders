# 示例环境变量（不要在仓库提交真实密码）
# 复制此文件为 .env 并修改为实际值

# =============================================================================
# Flask / 应用配置
# =============================================================================

# 应用密钥 - 用于 session 加密，生产环境应使用强随机字符串
SECRET_KEY=your-secret-key-here

# 访问控制口令 - 用于分析页面访问验证
ANALYSIS_ACCESS_CODE=your-access-code

# Flask 调试模式 - 生产环境必须设为 false
# 可选值：true, false, 1, 0
FLASK_DEBUG=false

# =============================================================================
# 数据库配置
# =============================================================================

DB_HOST=localhost
DB_USER=bidding_user
DB_PASSWORD=your_db_password
DB_NAME=bidding_db
DB_PORT=3306

# =============================================================================
# 日志与监控
# =============================================================================

# 是否启用 JSON 行格式日志（true/false）
LOG_JSON=false

# 日志按日轮转保留天数
LOG_BACKUP_DAYS=7

# =============================================================================
# 数据清理
# =============================================================================

# 清理脚本保留的天数（clear_old_data.py 默认值）
CLEANUP_DAYS=30

# =============================================================================
# 用户认证配置
# =============================================================================

# 用户配置 - 用于登录认证（格式：用户名：密码哈希，多个用户用分号分隔）
# 使用 tools/generate_password.py 生成密码哈希
# 示例：USERS_CONFIG=admin:pbkdf2:sha256:260000$xyz$...;user2:hash2
USERS_CONFIG=
